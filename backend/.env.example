# Copy this file to `.env` and fill in your key:
#   cp backend/.env.example backend/.env
#
# Optional: the key can also be entered directly in the app's launcher screen,
# or exported as an environment variable. Without a key the app runs in mock mode.
OPENAI_API_KEY=

# Optional server overrides
# AGENT_HOST=127.0.0.1
# AGENT_PORT=8000
# AGENT_MOCK=0
